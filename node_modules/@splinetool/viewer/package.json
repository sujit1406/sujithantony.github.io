{
  "name": "@splinetool/viewer",
  "version": "1.12.90",
  "description": "Spline is a collaborative design platform for creating production-ready interactive experiences in multiple dimensions. © 2025 Spline, Inc.",
  "keywords": [
    "spline",
    "3D",
    "webgl",
    "shader",
    "interactive",
    "collaborative",
    "web-components",
    "lit-element",
    "typescript",
    "lit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/splinetool/spline.git",
    "directory": "packages/viewer"
  },
  "type": "module",
  "main": "./build/spline-viewer.js",
  "module": "./build/spline-viewer.js",
  "types": "./build/spline-viewer.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./build/spline-viewer.d.ts",
      "import": "./build/spline-viewer.js",
      "require": "./build/spline-viewer.cjs"
    }
  },
  "files": [
    "build",
    "README.md"
  ],
  "scripts": {
    "build": "cross-env NODE_ENV=production node --experimental-json-modules ./esbuild.mjs && npm run build-types",
    "build-types": "tsc --skipLibCheck --isolatedModules false --noEmit false --emitDeclarationOnly --declaration --outDir build/ --declarationMap false",
    "format": "prettier src/ --write",
    "typecheck": "tsc",
    "prepublishOnly": "node ../../scripts/verify-publish-target.mjs",
    "example": "cross-env IS_PROD=true npm run build && vite",
    "test": "npm run test:dev && npm run test:prod",
    "test:dev": "wtr src",
    "test:prod": "MODE=prod wtr src"
  },
  "dependencies": {
    "lit": "2.6.0"
  },
  "devDependencies": {
    "@open-wc/testing": "3.2.2",
    "@splinetool/runtime": "*",
    "@web/dev-server-esbuild": "1.0.4",
    "@web/dev-server-legacy": "2.1.1",
    "@web/test-runner": "0.20.2",
    "@webcomponents/webcomponentsjs": "2.7.0",
    "cross-env": "7.0.3",
    "esbuild": "0.15.16",
    "prettier": "2.6.2",
    "rimraf": "3.0.2",
    "typescript": "^5.2.2",
    "vite": "5.4.10",
    "vite-plugin-static-copy": "0.13.0"
  }
}
